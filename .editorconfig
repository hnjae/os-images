root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
tab_width = 8

[{justfile.justfile}]
indent_size = 4
indent_style = space

[*.{yml,yaml}]
indent_size = 2
indent_style = space

[*.{md}]
indent_size = 4
indent_style = space

[*.{sh,bash,fish,zsh}]
indent_size = 4
indent_style = space

[.{env,envrc}]
indent_size = 4
indent_style = space

[.{env,envrc}.*]
indent_size = 4
indent_style = space
